rules_version = '2';

// Users can only read/write their own data. The web client key is public,
// so these rules are the ONLY thing stopping other people from reading a
// user's cart/orders — keep them strict.
service cloud.firestore {
  match /databases/{database}/documents {

    // A signed-in user may only touch documents under users/{theirUid}/...
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public, signed-out users get nothing.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
